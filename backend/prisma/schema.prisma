// Prisma schema — Nimbus backend (Phase 2)
// Run `npm run prisma:migrate` after setting DATABASE_URL in .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  STARTER
  PRO
  TEAM
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  passwordHash   String
  avatarInitials String
  plan           Plan     @default(STARTER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("users")
}

// Stored (hashed) so a leaked DB row can't be replayed as a live session,
// and so individual sessions/devices can be revoked without a password reset.
model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}
