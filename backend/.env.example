# Server
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://neondb_owner:npg_nOLcVDveB6P2@ep-summer-union-aib80wzl-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_TOKEN_EXPIRES_IN=30m

# bcrypt
BCRYPT_SALT_ROUNDS=12

# Nextcloud OCS Provisioning API (server-side only — never sent to the client)
# Use an app password, not the admin account's real login password:
# Nextcloud > Settings > Security > "Devices & sessions" > Create new app password
NEXTCLOUD_URL=https://cloud.example.com
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=replace-with-an-app-password

# Logging
LOG_LEVEL=info
