# Server
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://nimbus:nimbus@localhost:5432/nimbus?schema=public"

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_TOKEN_EXPIRES_IN=30m

# bcrypt
BCRYPT_SALT_ROUNDS=12

# Nextcloud is provisioned via a small standalone agent (see
# ../nextcloud-agent) running ON the Nextcloud server — NOT the OCS HTTP
# API (currently-open Nextcloud bug, server#51637, rejects sensitive
# requests even with a valid app password) and NOT SSH from this machine
# (no private key needed here). See README > Nextcloud integration.
NEXTCLOUD_AGENT_URL=http://141.148.216.121:4100
# Must exactly match AGENT_TOKEN in nextcloud-agent's own .env.
NEXTCLOUD_AGENT_TOKEN=replace-with-the-same-token-set-in-the-agent

# Logging
LOG_LEVEL=info
